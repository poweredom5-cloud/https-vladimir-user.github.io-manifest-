<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Projects - GitHub Pages</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <h1 class="logo">My Projects</h1>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <header id="home" class="hero">
        <div class="container">
            <h1>Welcome to My Portfolio</h1>
            <p>Showcase of my projects and work</p>
        </div>
    </header>

    <section id="projects" class="projects">
        <div class="container">
            <h2>Featured Projects</h2>
            <div class="project-grid">
                <div class="project-card">
                    <h3>Project One</h3>
                    <p>Description of your first project goes here.</p>
                    <a href="#" class="btn">View Project</a>
                </div>
                <div class="project-card">
                    <h3>Project Two</h3>
                    <p>Description of your second project goes here.</p>
                    <a href="#" class="btn">View Project</a>
                </div>
                <div class="project-card">
                    <h3>Project Three</h3>
                    <p>Description of your third project goes here.</p>
                    <a href="#" class="btn">View Project</a>
                </div>
            </div>
        </div>
    </section>

    <footer id="contact" class="footer">
        <div class="container">
            <h3>Get In Touch</h3>
            <p>Email: your.email@example.com</p>
            <p>&copy; 2026 My Projects. All rights reserved.</p>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
